# Copia a .env y ajusta.

# Clave simple de acceso (single-user). El cliente Android la manda en X-API-Key.
XENGLISH_API_KEY=cambia-esta-clave

# Almacenamiento
XENGLISH_DATA_DIR=./data
XENGLISH_DB_URL=sqlite+aiosqlite:///./data/xenglish.db

# --- Whisper ---
XENGLISH_WHISPER_MODEL=large-v3
XENGLISH_WHISPER_DEVICE=cuda
XENGLISH_WHISPER_COMPUTE_TYPE=int8_float16

# --- LLM (llama.cpp) ---
# Ruta al modelo GGUF descargado (p.ej. Qwen2.5-7B-Instruct-Q4_K_M.gguf)
XENGLISH_LLM_MODEL_PATH=./models/qwen2.5-7b-instruct-q4_k_m.gguf
XENGLISH_LLM_N_GPU_LAYERS=-1
XENGLISH_LLM_N_CTX=4096
# Idioma de la explicacion pedagogica
XENGLISH_EXPLANATION_LANG=es

# --- TTS ---
XENGLISH_TTS_ENGINE=piper
# Ruta al modelo de voz Piper (.onnx) + su .json
XENGLISH_PIPER_MODEL_PATH=./models/en_US-amy-medium.onnx

# Limites de audio de entrada
XENGLISH_MAX_AUDIO_SECONDS=30
